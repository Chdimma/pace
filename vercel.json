{
  "version": 2,
  "builds": [
    {
      "src": "vercel.sh",
      "use": "@vercel/static-build",
      "config": { "distDir": "build/web" }
    }
  ],
  "buildCommand": "bash vercel.sh",
  "routes": [
    
    {
      "src": "/(.*\\.(?:css|js|png|jpg|jpeg|gif|svg|ico|json|woff|woff2|ttf|txt|map))",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
